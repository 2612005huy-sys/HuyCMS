@model IEnumerable<CMS.Data.Entities.Order>
@* =========================================================================
   👤 Sinh viên: Triệu Quốc Huy | MSSV: 2123110151
   📅 Ngày cập nhật: 23/05/2026
   📝 Chức năng: FILE VIEW INDEX CHUẨN - Hiển thị danh sách đơn hàng toàn hệ thống
   ========================================================================= *@

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="text-dark font-weight-bold">🛒 QUẢN LÝ ĐƠN HÀNG THƯƠNG MẠI</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4 border-start border-success border-4" role="alert">
            <i class="bi bi-check-circle-fill text-success me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 bg-white">
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center" style="width: 8%;">Mã ĐH</th>
                        <th style="width: 22%;">Khách hàng đặt</th>
                        <th style="width: 18%;">Ngày mua</th>
                        <th style="width: 22%;">Trạng thái đơn</th>
                        <th class="text-center" style="width: 30%;">Thao tác xử lý</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center font-weight-bold text-dark">#@item.Id</td>
                            <td><strong class="text-dark">@(item.Customer != null ? item.Customer.FullName : "Khách hàng hệ thống")</strong></td>
                            <td class="text-secondary">@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.Status == 0)
                                {
                                    <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-clock-history"></i> Chờ duyệt đơn</span>
                                }
                                else if (item.Status == 1)
                                {
                                    <span class="badge bg-primary text-white px-3 py-2"><i class="bi bi-truck"></i> Đang giao hàng</span>
                                }
                                else if (item.Status == 2)
                                {
                                    <span class="badge bg-success text-white px-3 py-2"><i class="bi bi-check-circle-fill"></i> Đã hoàn thành</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-inline-flex gap-1">
                                    <a asp-controller="Order" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info font-weight-bold text-dark">
                                        <i class="bi bi-gear-fill"></i> Xử lý đơn
                                    </a>
                                    <a asp-controller="Order" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger font-weight-bold" 
                                       onclick="return confirm('Huy có chắc chắn muốn hủy và xóa hoàn toàn hóa đơn này không?')">
                                        <i class="bi bi-x-circle"></i> Hủy đơn
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>