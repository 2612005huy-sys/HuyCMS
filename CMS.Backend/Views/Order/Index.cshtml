@model IEnumerable<dynamic>

<div class="container mt-4">
    <h2 class="mb-4 text-primary">🛒 QUẢN LÝ ĐƠN HÀNG</h2>

    <table class="table table-bordered table-striped shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Mã Đơn</th>
                <th>Ngày Đặt</th>
                <th>Tổng Tiền</th>
                <th>Trạng Thái</th>
                <th>Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>#@item.Id</td>
                    <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="text-danger font-weight-bold">@string.Format("{0:N0} đ", item.TotalAmount)</td>
                    <td>
                        <span class="badge bg-warning text-dark">Chờ xử lý</span>
                    </td>
                    <td>
                        <a href="/Order/Details/@item.Id" class="btn btn-sm btn-info text-white">
                            Xem chi tiết sản phẩm mua
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>