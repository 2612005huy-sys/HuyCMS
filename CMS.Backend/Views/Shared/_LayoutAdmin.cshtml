<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThaiCMS Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
        }

        .sidebar {
            min-height: 100vh;
            background: linear-gradient(180deg, #1e2640 0%, #111827 100%);
            color: #e5e7eb;
            transition: all 0.3s ease;
        }

        .sidebar a {
            color: #9ca3af;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px;
            margin: 4px 12px;
            border-radius: 8px;
            font-size: 0.925rem;
            font-weight: 500;
            transition: all 0.2s ease-in-out;
        }

        .sidebar a i {
            font-size: 1.1rem;
            transition: transform 0.2s ease;
        }

        .sidebar a:hover {
            background-color: rgba(255, 255, 255, 0.08);
            color: #ffffff;
            transform: translateX(4px);
        }

        .sidebar a:hover i {
            transform: scale(1.15);
        }

        .sidebar .active {
            background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%) !important;
            color: white !important;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
        }
        
        .admin-brand {
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .main-content {
            background-color: #f3f4f6;
            min-height: 100vh;
        }

        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .card:hover {
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -2px rgba(0, 0, 0, 0.04);
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 sidebar p-0 shadow d-flex flex-column justify-content-between">
                <div>
                    <div class="p-3 text-center border-bottom border-secondary">
                        <h4 class="text-white mb-0"><i class="bi bi-shield-lock-fill text-warning"></i> HuyCMS Admin</h4>
                    </div>
                    <div class="mt-3">
                        <a asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2"></i> Bảng điều khiển</a>
                        <a asp-controller="Category" asp-action="Index"><i class="bi bi-grid"></i> Quản lý Danh mục</a>
                        <a asp-controller="Post" asp-action="Index"><i class="bi bi-file-earmark-post"></i> Quản lý Bài viết</a>
                        <a asp-controller="User" asp-action="Index"><i class="bi bi-people"></i> Quản lý Thành viên</a>
                        
                        <div class="border-top border-secondary my-2"></div>
                        
                        <a asp-controller="CategoryProduct" asp-action="Index"><i class="bi bi-folder2-open"></i> Quản lý DM Sản phẩm</a>
                        <a asp-controller="Color" asp-action="Index"><i class="bi bi-palette"></i> Quản lý Bảng màu</a>
                        <a asp-controller="Product" asp-action="Index"><i class="bi bi-box-seam"></i> Quản lý Sản phẩm</a>
                        <a asp-controller="Customer" asp-action="Index"><i class="bi bi-person-badge"></i> Quản lý Khách hàng</a>
                        <a asp-controller="Order" asp-action="Index"><i class="bi bi-cart3"></i> Quản lý Đơn hàng</a>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="border-top border-secondary my-2"></div>
                            <a asp-controller="Trash" asp-action="Index" style="color: #f87171 !important;"><i class="bi bi-trash3-fill text-danger"></i> Thùng rác hệ thống</a>
                        }
                    </div>
                </div>

                <div class="p-3 border-top border-secondary bg-transparent">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="small text-muted mb-1" style="font-size: 0.8rem;">👤 Tài khoản:</div>
                        <div class="text-white fw-bold text-truncate mb-2" title="@User.FindFirst("FullName")?.Value" style="font-size: 0.9rem;">
                            @User.FindFirst("FullName")?.Value
                        </div>
                        
                        <div class="mb-3">
                            @if (User.IsInRole("Admin"))
                            {
                                <span class="badge bg-danger shadow-sm w-100 py-1" style="font-size: 0.75rem;">Quản trị viên</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark shadow-sm w-100 py-1" style="font-size: 0.75rem;">Biên tập viên</span>
                            }
                        </div>
                        
                        <a class="btn btn-sm btn-outline-danger w-100 fw-semibold" asp-controller="Account" asp-action="Logout" style="font-size: 0.8rem; border-radius: 6px;">
                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-primary w-100 fw-semibold" asp-controller="Account" asp-action="Login" style="font-size: 0.8rem; border-radius: 6px;">
                            <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                        </a>
                    }
                </div>
            </nav>

            <main class="col-md-9 col-lg-10 ms-sm-auto p-4 main-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            var currentPath = window.location.pathname.toLowerCase();
            $('.sidebar a').each(function() {
                var href = $(this).attr('href');
                if (href) {
                    href = href.toLowerCase();
                    // So sánh chính xác hoặc so sánh tiền tố
                    if (currentPath === href || (href !== '/' && href !== '/home' && currentPath.indexOf(href) === 0)) {
                        $(this).addClass('active');
                    }
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>