@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thùng rác hệ thống";
    var deletedProducts = ViewBag.DeletedProducts as List<CMS.Data.Entities.Product> ?? new List<CMS.Data.Entities.Product>();
    var deletedPosts = ViewBag.DeletedPosts as List<CMS.Data.Entities.Post> ?? new List<CMS.Data.Entities.Post>();
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-1"><i class="bi bi-trash3 text-danger"></i> THÙNG RÁC HỆ THỐNG</h2>
            <p class="text-muted mb-0" style="font-size: 0.9rem;">Khôi phục lại dữ liệu đã xóa tạm thời hoặc xóa vĩnh viễn khỏi hệ thống.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-start border-success border-4 mb-4" role="alert">
            <i class="bi bi-check-circle-fill text-success me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Tabs phân chia Sản phẩm & Bài viết -->
    <div class="card shadow-sm border-0 bg-white p-3">
        <ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-semibold" id="pills-products-tab" data-bs-toggle="pill" data-bs-target="#pills-products" type="button" role="tab" aria-controls="pills-products" aria-selected="true">
                    <i class="bi bi-box-seam"></i> Sản phẩm đã xóa (@deletedProducts.Count)
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-semibold ms-2" id="pills-posts-tab" data-bs-toggle="pill" data-bs-target="#pills-posts" type="button" role="tab" aria-controls="pills-posts" aria-selected="false">
                    <i class="bi bi-file-earmark-post"></i> Bài viết đã xóa (@deletedPosts.Count)
                </button>
            </li>
        </ul>

        <div class="tab-content" id="pills-tabContent">
            <!-- TAB SẢN PHẨM -->
            <div class="tab-pane fade show active" id="pills-products" role="tabpanel" aria-labelledby="pills-products-tab">
                @if (deletedProducts.Count == 0)
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-folder2-open display-4 text-secondary"></i>
                        <p class="mt-3 mb-0 fw-medium">Thùng rác sản phẩm trống rỗng!</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 8%;">Hình ảnh</th>
                                    <th>Tên sản phẩm</th>
                                    <th>Danh mục</th>
                                    <th>Giá tiền</th>
                                    <th class="text-center">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in deletedProducts)
                                {
                                    <tr>
                                        <td class="text-center">
                                            <img src="@item.ImageUrl" class="rounded border" style="width: 48px; height: 48px; object-fit: cover;" alt="" />
                                        </td>
                                        <td><strong class="text-dark">@item.Name</strong></td>
                                        <td class="text-secondary">@(item.CategoryProduct != null ? item.CategoryProduct.Name : "Chưa phân loại")</td>
                                        <td class="text-danger fw-semibold">@item.Price.ToString("#,##0") đ</td>
                                        <td class="text-center">
                                            <a asp-controller="Trash" asp-action="RestoreProduct" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success fw-medium me-1">
                                                <i class="bi bi-arrow-counterclockwise"></i> Khôi phục
                                            </a>
                                            <a asp-controller="Trash" asp-action="DeleteProductPermanently" asp-route-id="@item.Id" class="btn btn-sm btn-danger fw-medium"
                                               onclick="return confirm('CẢNH BÁO: Hành động này sẽ xóa VĨNH VIỄN sản phẩm này và không thể phục hồi! Bạn có chắc muốn tiếp tục?')">
                                                <i class="bi bi-trash"></i> Xóa vĩnh viễn
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- TAB BÀI VIẾT -->
            <div class="tab-pane fade" id="pills-posts" role="tabpanel" aria-labelledby="pills-posts-tab">
                @if (deletedPosts.Count == 0)
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-folder2-open display-4 text-secondary"></i>
                        <p class="mt-3 mb-0 fw-medium">Thùng rác bài viết trống rỗng!</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 8%;">Hình ảnh</th>
                                    <th>Tiêu đề bài viết</th>
                                    <th>Danh mục bài viết</th>
                                    <th>Ngày tạo</th>
                                    <th class="text-center">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in deletedPosts)
                                {
                                    <tr>
                                        <td class="text-center">
                                            <img src="@item.ImageUrl" class="rounded border" style="width: 48px; height: 48px; object-fit: cover;" alt="" />
                                        </td>
                                        <td><strong class="text-dark">@item.Title</strong></td>
                                        <td class="text-secondary">@(item.Category != null ? item.Category.Name : "Chưa phân loại")</td>
                                        <td class="text-muted" style="font-size: 0.85rem;">@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="text-center">
                                            <a asp-controller="Trash" asp-action="RestorePost" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success fw-medium me-1">
                                                <i class="bi bi-arrow-counterclockwise"></i> Khôi phục
                                            </a>
                                            <a asp-controller="Trash" asp-action="DeletePostPermanently" asp-route-id="@item.Id" class="btn btn-sm btn-danger fw-medium"
                                               onclick="return confirm('CẢNH BÁO: Hành động này sẽ xóa VĨNH VIỄN bài viết này và không thể phục hồi! Bạn có chắc muốn tiếp tục?')">
                                                <i class="bi bi-trash"></i> Xóa vĩnh viễn
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
