   🆔 MSSV: 2123110151
   📝 Chức năng: FILE HOÀN CHỈNH - Chi tiết bài viết (Sửa lỗi hiển thị HTML & tối ưu UI)
   ========================================================================= *@

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent p-0 mb-4">
            <li class="breadcrumb-item"><a href="/Post" class="text-decoration-none text-muted"><i class="bi bi-house-door-fill me-1"></i>Danh sách bài viết</a></li>
            <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Chi tiết</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-9 col-md-11">
            
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-warning text-dark px-3 py-2 fw-bold shadow-sm rounded-pill">
                    🏷️ @Model.Category.Name
                </span>
                <span class="text-muted small">
                    <i class="bi bi-clock me-1"></i> @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                </span>
            </div>

            <h1 class="fw-extrabold text-dark mb-4" style="font-size: 2.5rem; letter-spacing: -0.5px; line-height: 1.3;">
                @Model.Title
            </h1>
            
            <hr class="my-4 opacity-75" />

            <div class="text-center mb-5 position-relative">
                <img src="@Model.ImageUrl" class="img-fluid rounded shadow-lg" alt="@Model.Title" 
                     style="width: 100%; max-height: 480px; object-fit: cover;">
            </div>

            <div class="post-content text-dark mb-5" style="font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 1.15rem; line-height: 1.9; letter-spacing: 0.2px;">
                @Html.Raw(Model.Content)
            </div>

            <div class="mt-5 border-top pt-4 mb-5 d-flex justify-content-between align-items-center">
                <a href="/Post" class="btn btn-outline-secondary px-4 py-2 rounded-pill shadow-sm transition-all">
                    <i class="bi bi-arrow-left me-2"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .post-content p {
        margin-bottom: 1.5rem;
    }
    .post-content img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 1.5rem auto;
        display: block;
        shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
    .post-content h2, .post-content h3 {
        font-weight: 700;
        color: #1a1a1a;
        margin-top: 2rem;
        margin-bottom: 1rem;
    }
    .transition-all {
        transition: all 0.3s ease;
    }
    .transition-all:hover {
        transform: translateX(-3px);
    }
</style>