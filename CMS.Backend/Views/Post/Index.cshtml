@model IEnumerable<dynamic>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý bài viết";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-dark font-weight-bold">📝 DANH SÁCH BÀI VIẾT QUẢN TRỊ</h2>
        <a asp-action="Create" class="btn btn-success font-weight-bold">
            <i class="bi bi-plus-circle"></i> Thêm bài viết mới
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <img src="@item.ImageUrl" class="card-img-top" alt="Thumbnail" style="height: 180px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <div class="mb-2">
                            <span class="badge bg-info text-dark">@item.Category.Name</span>
                        </div>
                        <h5 class="card-title text-primary font-weight-bold">@item.Title</h5>
                        <p class="card-text text-muted text-truncate">@item.Content</p>
                        <p class="text-secondary small mt-auto">📅 Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")</p>

                        <div class="d-flex justify-content-between mt-3 border-top pt-2">
                            <a href="/Post/Details/@item.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                            <div>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"
                                   onclick="return confirm('Chúng ta có chắc chắn muốn xóa bài viết này không?')">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>