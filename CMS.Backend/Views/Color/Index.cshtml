@model IEnumerable<CMS.Data.Entities.Color>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý Bảng màu";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark font-weight-bold">🎨 QUẢN LÝ BẢNG MÀU SẮC</h2>
        <a asp-action="Create" class="btn btn-success font-weight-bold shadow-sm">
            <i class="bi bi-plus-circle"></i> Thêm màu mới
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4 border-start border-danger border-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4 border-start border-success border-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 bg-white">
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center" style="width: 15%;">Mã ID</th>
                        <th style="width: 30%;">Tên Màu Sắc</th>
                        <th class="text-center" style="width: 20%;">Mã Hex</th>
                        <th class="text-center" style="width: 15%;">Hiển thị</th>
                        <th class="text-center" style="width: 20%;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center fw-bold text-secondary">@item.Id</td>
                            <td><strong class="text-primary">@item.Name</strong></td>
                            <td class="text-center text-secondary">@item.HexCode</td>
                            <td class="text-center">
                                <div style="width: 30px; height: 30px; background-color: @item.HexCode; border-radius: 50%; display: inline-block; border: 1px solid #ddd; box-shadow: 0 2px 5px rgba(0,0,0,0.1);"></div>
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning font-weight-bold me-1">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger font-weight-bold" onclick="return confirm('Bạn có chắc muốn xóa màu sắc này khỏi hệ thống?')"><i class="bi bi-trash"></i> Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
