@model CMS.Backend.Models.DashboardViewModel

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Bảng điều khiển Doanh Thu";
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 fw-bold"><i class="bi bi-speedometer2"></i> TỔNG QUAN HỆ THỐNG</h1>
        <a href="#" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
            <i class="bi bi-download"></i> Tải báo cáo
        </a>
    </div>

    <!-- Thống kê doanh thu và chỉ số -->
    <div class="row mb-4">
        <!-- Tổng doanh thu -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 shadow h-100 py-2" style="border-left: 5px solid #1cc88a !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">
                                TỔNG DOANH THU
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800 fs-4">
                                @Model.TotalRevenue.ToString("N0") VNĐ
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-cash-stack fa-2x text-gray-300" style="font-size: 2.5rem; color: #dddfeb;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Số lượng đơn hàng -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 shadow h-100 py-2" style="border-left: 5px solid #4e73df !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">
                                TỔNG ĐƠN HÀNG
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800 fs-4">@Model.TotalOrders</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-cart-check-fill fa-2x text-gray-300" style="font-size: 2.5rem; color: #dddfeb;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Khách hàng -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 shadow h-100 py-2" style="border-left: 5px solid #36b9cc !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">
                                KHÁCH HÀNG ĐĂNG KÝ
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800 fs-4">@Model.TotalCustomers</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-people-fill fa-2x text-gray-300" style="font-size: 2.5rem; color: #dddfeb;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sản phẩm trong kho -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 shadow h-100 py-2" style="border-left: 5px solid #f6c23e !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">
                                MẶT HÀNG TRONG KHO
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800 fs-4">@Model.TotalProducts</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-box-seam-fill fa-2x text-gray-300" style="font-size: 2.5rem; color: #dddfeb;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Đơn hàng mới nhất -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow border-0 h-100">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between bg-white border-bottom">
                    <h6 class="m-0 font-weight-bold text-primary"><i class="bi bi-clock-history"></i> Đơn hàng vừa đặt gần đây</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 text-center">
                            <thead class="table-light text-secondary">
                                <tr>
                                    <th>Mã ĐH</th>
                                    <th>Thời gian đặt</th>
                                    <th>Tên Khách hàng</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentOrders != null && Model.RecentOrders.Any())
                                {
                                    foreach (var order in Model.RecentOrders)
                                    {
                                        <tr>
                                            <td class="fw-bold text-primary">#@order.Id</td>
                                            <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="fw-bold text-dark">@(order.Customer != null ? order.Customer.FullName : "Khách vãng lai")</td>
                                            <td>
                                                @if (order.Status == 0)
                                                {
                                                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="bi bi-hourglass-split"></i> Chờ duyệt</span>
                                                }
                                                else if (order.Status == 1)
                                                {
                                                    <span class="badge bg-info px-3 py-2 rounded-pill"><i class="bi bi-truck"></i> Đang giao</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success px-3 py-2 rounded-pill"><i class="bi bi-check-circle"></i> Đã giao</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">
                                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                            Chưa có đơn hàng nào được đặt.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Giữ lại danh sách bài viết ở dưới thu nhỏ sang bên phải -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow border-0 h-100">
                <div class="card-header py-3 bg-white border-bottom">
                    <h6 class="m-0 font-weight-bold text-secondary"><i class="bi bi-newspaper"></i> Tin tức mới</h6>
                </div>
                <div class="card-body">
                    @if (Model.RecentPosts != null && Model.RecentPosts.Any())
                    {
                        foreach (var post in Model.RecentPosts)
                        {
                            <div class="d-flex mb-3 align-items-center">
                                <img src="@post.ImageUrl" class="rounded" style="width: 70px; height: 70px; object-fit: cover;" alt="@post.Title">
                                <div class="ms-3">
                                    <span class="badge bg-light text-dark border mb-1">@(post.Category != null ? post.Category.Name : "Tin tức")</span>
                                    <h6 class="fw-bold text-dark mb-0" style="font-size: 0.9rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@post.Title</h6>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>