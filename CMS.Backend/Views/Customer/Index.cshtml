@model IEnumerable<CMS.Data.Entities.Customer>
@* =========================================================================
   👤 Sinh viên: Triệu Quốc Huy | MSSV: 2123110151
   📅 Ngày tạo/cập nhật: 23/05/2026
   📝 Chức năng: Giao diện quản lý tài khoản khách hàng, hiển thị số điện thoại, email
   ========================================================================= *@

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý khách hàng";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="text-dark font-weight-bold">👤 QUẢN LÝ THÔNG TIN KHÁCH HÀNG</h2>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4 border-start border-danger border-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 bg-white">
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center" style="width: 8%;">ID</th>
                        <th style="width: 22%;">Họ tên khách hàng</th>
                        <th style="width: 25%;">Hộp thư (Email)</th>
                        <th style="width: 15%;">Số điện thoại</th>
                        <th style="width: 15%;">Mật khẩu thô</th>
                        <th class="text-center" style="width: 15%;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center font-weight-bold text-secondary">@item.Id</td>
                            <td><strong class="text-primary">@item.FullName</strong></td>
                            <td class="text-secondary">@item.Email</td>
                            <td class="fw-bold">@item.Phone</td>
                            <td class="text-muted text-monospace">@item.Password</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning font-weight-bold me-1">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger font-weight-bold" onclick="return confirm('Bạn có chắc chắn muốn xóa tài khoản khách hàng này?')"><i class="bi bi-trash"></i> Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>