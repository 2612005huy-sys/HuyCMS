@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa khách hàng";
}

<div class="container mt-4" style="max-width: 650px;">
    <div class="card shadow border-0">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0 font-weight-bold"><i class="bi bi-person-gear"></i> CHỈNH SỬA THÔNG TIN KHÁCH HÀNG</h4>
        </div>
        <div class="card-body bg-white">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Họ và tên khách hàng:</label>
                    <input asp-for="FullName" class="form-control" placeholder="Nhập tên khách hàng..." required />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Địa chỉ Email:</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com" required />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Số điện thoại liên hệ:</label>
                    <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại..." />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Địa chỉ giao hàng mặc định:</label>
                    <input asp-for="Address" class="form-control" placeholder="Nhập số nhà, tên đường, tỉnh thành..." />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mật khẩu tài khoản (Thô):</label>
                    <input asp-for="Password" type="text" class="form-control" placeholder="Nhập mật khẩu cấp lại..." required />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <hr />
                <div class="d-flex justify-content-between mt-3">
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
                    <button type="submit" class="btn btn-warning font-weight-bold text-dark">💾 Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>