@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0 font-weight-bold"><i class="bi bi-pencil-square"></i> CHỈNH SỬA THÔNG TIN SẢN PHẨM</h4>
        </div>
        <div class="card-body bg-white">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />

                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên sản phẩm:</label>
                            <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô tả & Thông tin chi tiết sản phẩm:</label>
                            <textarea asp-for="Description" class="form-control" rows="10" placeholder="Thông số, tính năng sản phẩm..."></textarea>
                        </div>
                    </div>

                    <div class="col-md-4 bg-light p-3 rounded border">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Danh mục sản phẩm:</label>
                            <select asp-for="CategoryProductId" class="form-select fw-bold text-primary" asp-items="ViewBag.CategoryProductList" required>
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                            <span asp-validation-for="CategoryProductId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Giá bán hiện tại (VNĐ):</label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control fw-bold text-danger" required />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Số lượng tồn kho:</label>
                            <input asp-for="StockQuantity" type="number" class="form-control" required />
                            <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ảnh đại diện hiện tại:</label>
                            <div class="mb-2 text-center bg-white p-2 border rounded">
                                <img src="@Model.ImageUrl" class="img-thumbnail" style="max-height: 120px; object-fit: cover;" alt="Current Image" />
                            </div>
                            <label class="form-label fw-bold text-secondary small">Tải lên ảnh mới nếu muốn thay đổi:</label>
                            <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                        </div>

                        <hr />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning font-weight-bold text-dark">
                                <i class="bi bi-download"></i> Cập nhật thay đổi
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

<script src="https://cdn.jsdelivr.net/npm/@@ckeditor/ckeditor5-build-classic/build/ckeditor.js"></script>
    
    <script>
        ClassicEditor
            .create(document.querySelector('#Description'), {
                placeholder: 'Nhập thông tin chi tiết phom dáng, chất liệu vải, thông số kỹ thuật hoặc hướng dẫn bảo quản sản phẩm...'
            })
            .catch(error => {
                console.error(error);
            });
    </script>
    
    <style>
        .ck-editor__editable_inline {
            min-height: 280px;
        }
    </style>
}