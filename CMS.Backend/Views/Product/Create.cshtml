@model CMS.Data.Entities.Product
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-plus-square-fill"></i> TẠO MỚI SẢN PHẨM</h4>
        </div>
        <div class="card-body bg-white">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên sản phẩm:</label>
                            <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô tả sản phẩm:</label>
                            <textarea asp-for="Description" class="form-control" rows="10" placeholder="Thông số, tính năng sản phẩm..."></textarea>
                        </div>
                    </div>

                    <div class="col-md-4 bg-light p-3 rounded border">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Danh mục:</label>
                            <select asp-for="CategoryProductId" class="form-select" asp-items="ViewBag.CategoryProductList" required>
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                            <span asp-validation-for="CategoryProductId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Giá bán (VNĐ):</label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Ví dụ: 500000" required />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Số lượng tồn kho:</label>
                            <input asp-for="StockQuantity" type="number" class="form-control" placeholder="Nhập số lượng..." required />
                            <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ảnh đại diện:</label>
                            <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                        </div>

                        <hr />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success font-weight-bold">
                                <i class="bi bi-save"></i> Lưu và Đăng sản phẩm
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>