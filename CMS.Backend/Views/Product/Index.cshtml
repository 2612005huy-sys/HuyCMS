@model IEnumerable<CMS.Data.Entities.Product>
@* =========================================================================
   👤 Sinh viên: Triệu Quốc Huy | MSSV: 2123110151
   📅 Ngày tạo/cập nhật: 23/05/2026
   📝 Chức năng: FILE HOÀN CHỈNH - Giao diện danh sách sản phẩm quản trị kèm nút thao tác chuẩn
   ========================================================================= *@

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark font-weight-bold">📦 QUẢN LÝ DANH SÁCH SẢN PHẨM</h2>
        <a asp-controller="Product" asp-action="Create" class="btn btn-success font-weight-bold shadow-sm">
            <i class="bi bi-plus-circle"></i> Thêm sản phẩm mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4 border-start border-success border-4" role="alert">
            <i class="bi bi-check-circle-fill text-success me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 bg-white">
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center" style="width: 8%;">Hình ảnh</th>
                        <th style="width: 25%;">Tên sản phẩm</th>
                        <th style="width: 20%;">Danh mục hàng</th>
                        <th style="width: 17%;">Giá bán (VNĐ)</th>
                        <th class="text-center" style="width: 10%;">Tồn kho</th>
                        <th class="text-center" style="width: 20%;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="@item.ImageUrl" class="rounded border" style="width: 50px; height: 50px; object-fit: cover;" alt="Product Image" />
                            </td>
                            <td><strong class="text-dark">@item.Name</strong></td>
                            <td class="text-secondary">@(item.CategoryProduct != null ? item.CategoryProduct.Name : "Chưa phân loại")</td>
                            <td class="text-danger fw-bold">@item.Price.ToString("#,##0.00") đ</td>
                            <td class="text-center fw-bold @(item.StockQuantity <= 5 ? "text-danger" : "text-success")">@item.StockQuantity</td>
                            <td class="text-center">
                                <a asp-controller="Product" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning font-weight-bold me-1">
                                    <i class="bi bi-pencil-square"></i> Sửa
                                </a>

                                <a asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger font-weight-bold" 
                                   onclick="return confirm('Huy có chắc chắn muốn xóa sản phẩm này ra khỏi hệ thống kho hàng không?')">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>