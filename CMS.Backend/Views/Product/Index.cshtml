@model IEnumerable<dynamic>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">📦 QUẢN LÝ SẢN PHẨM</h2>
        <button class="btn btn-success">+ Thêm sản phẩm mới</button>
    </div>

    <table class="table table-bordered table-striped shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tên Sản Phẩm</th>
                <th>Giá Bán</th>
                <th>Số Lượng</th>
                <th>Hình Ảnh</th>
                <th>Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td><strong>@item.Name</strong></td>
                    <td class="text-danger">@string.Format("{0:N0} đ", item.Price)</td>
                    <td>@item.Stock</td>
                    <td><img src="@item.ImageUrl" style="width: 60px; height: 40px; object-fit: cover;" /></td>
                    <td>
                        <button class="btn btn-sm btn-warning">Sửa</button>
                        <button class="btn btn-sm btn-danger">Xóa</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>